# ===== DATABASE (Supabase PostgreSQL) =====
# Lấy thông tin tại: Supabase Dashboard → Settings → Database → Connection string
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# ===== JWT =====
# Chuỗi bất kỳ >= 256 bits (32 ký tự trở lên)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-here

# ===== GOOGLE OAUTH2 =====
# Lấy tại: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== PAYOS =====
# Lấy tại: https://my.payos.vn/ → Thông tin tích hợp
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# ===== SUPABASE STORAGE =====
# Lấy tại: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===== REDIS (Upstash — serverless TLS) =====
# Tạo free DB tại: https://console.upstash.com → Redis → Create → copy REDIS_URL
REDIS_URL=rediss://:<password>@<host>:6380

# ===== EMAIL (Gmail SMTP) =====
# Tạo App Password tại: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ===== CORS (Frontend URL) =====
# Production: ALLOWED_ORIGINS=https://tapo-store.vercel.app
# Development: để mặc định (http://localhost:5173,http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== APP =====
# URL frontend — dùng trong email link (verify, reset password)
APP_BASE_URL=http://localhost:5173

# ===== SPRING PROFILE =====
# dev | prod — dùng prod khi deploy lên Railway/VPS
SPRING_PROFILES_ACTIVE=dev

# ===== KEEP-ALIVE (for free-tier hosting) =====
# Set true nếu dùng platform tự sleep sau inactivity
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_URL=http://localhost:8080/actuator/health
